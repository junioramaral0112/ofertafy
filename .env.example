# ═══════════════════════════════════════════════════════════
# OFERTAFY — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# ⚠️  NUNCA comite o .env no git (já está no .gitignore)

# ═══════════════════════════════════════════════════════════
# BANCO DE DADOS
# ═══════════════════════════════════════════════════════════
# Produção: PostgreSQL (Render, Railway, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Local: SQLite (desenvolvimento)
# DATABASE_URL="file:./dev.db"

# ═══════════════════════════════════════════════════════════
# 🟡 MERCADO LIVRE
# ═══════════════════════════════════════════════════════════
# Matt Tool = parâmetro de tracking do programa de afiliados ML
ML_MATT_TOOL="35888960"

# ═══════════════════════════════════════════════════════════
# 🔵 MAGALU / MAGAZINE LUIZA
# ═══════════════════════════════════════════════════════════
# ID da sua loja no Magazine Você
# Ex: magazinevoce.com.br/magazineOFERTAFY → ID = "OFERTAFY"
MAGALU_STORE_ID="ofertafy"

# ═══════════════════════════════════════════════════════════
# 🔴 SHOPEE (API GraphQL Oficial de Afiliados)
# ═══════════════════════════════════════════════════════════
# Obtidos no painel de afiliados: https://affiliate.shopee.com.br
SHOPEE_APP_ID=""
SHOPEE_SECRET=""

# ═══════════════════════════════════════════════════════════
# 🎵 TIKTOK SHOP (API Research)
# ═══════════════════════════════════════════════════════════
# u_code de afiliado (obtido ao compartilhar produto pelo app)
TIKTOK_AFFILIATE_ID=""
# Token de acesso à API (se disponível)
TIKTOK_ACCESS_TOKEN=""

# ═══════════════════════════════════════════════════════════
# 🟠 AMAZON (Puppeteer — preencha para ativar)
# ═══════════════════════════════════════════════════════════
AMAZON_ASSOCIATE_TAG=""
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""

# ═══════════════════════════════════════════════════════════
# 📱 WHATSAPP / TELEGRAM (disparo de ofertas)
# ═══════════════════════════════════════════════════════════
WHATSAPP_GROUP_URL=""
GROUP_WEBHOOK_URL=""

# ═══════════════════════════════════════════════════════════
# 🔒 SEGURANÇA
# ═══════════════════════════════════════════════════════════
# Segredo para proteger a rota /api/fetch e /api/cron
CRON_SECRET="seu-segredo-personalizado-aqui"

# Login do painel administrativo (/admin)
ADMIN_USER="admin"
ADMIN_PASSWORD="sua-senha-segura-aqui"

# ═══════════════════════════════════════════════════════════
# 📊 GOOGLE ANALYTICS 4
# ═══════════════════════════════════════════════════════════
# Measurement ID (formato: G-XXXXXXXXXX) obtido em admin.google.com
NEXT_PUBLIC_GA_ID="G-F1R04L8N36"

# ═══════════════════════════════════════════════════════════
# 🌐 URL DO SITE
# ═══════════════════════════════════════════════════════════
# Em produção: https://seudominio.com.br
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
